{
  "name": "yaya_msg",
  "version": "2.0.0",
  "description": "牙牙消息",
  "homepage": "https://github.com/yk1z/yaya_msg",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": {
    "name": "yk1z",
    "email": "yk1z@users.noreply.github.com"
  },
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "lamejs": "^1.2.1",
    "node-media-server": "^4.2.4"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "com.yaya.message",
    "productName": "牙牙消息",
    "executableName": "yaya_msg",
    "afterPack": "scripts/copy-ffmpeg.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "index.html",
      "style.css",
      "icon.png",
      "icon.ico",
      "members_id.csv",
      "rust-wasm.js",
      "rust-wasm-browser.js",
      "node_modules/**/*"
    ],
    "extraResources": [
      "2.wasm"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Utility",
      "maintainer": "yk1z <yk1z@users.noreply.github.com>",
      "desktop": {
        "entry": {
          "Name": "牙牙消息",
          "Icon": "yaya_msg",
          "StartupWMClass": "yaya_msg"
        }
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
